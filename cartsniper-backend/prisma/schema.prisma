// Prisma schema for CartSniper
// Using SQLite for hackathon simplicity (swap to PostgreSQL for production)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hashed
  pushToken String?  // Expo push notification token
  latitude  Float?   // User's location for nearby stores
  longitude Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  carts  Cart[]
  alerts Alert[]
}

model Product {
  id        String   @id @default(cuid())
  barcode   String   @unique
  name      String
  brand     String?
  category  String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prices     Price[]
  cartItems  CartItem[]
  alerts     Alert[]
  flyerItems FlyerItem[]
}

model Store {
  id               String  @id @default(cuid())
  name             String
  slug             String  @unique // walmart, loblaws, nofrills, freshco, metro
  logoUrl          String?
  latitude         Float
  longitude        Float
  address          String?
  priceMatchPolicy String? // Description of store's price match policy

  prices Price[]
  flyers Flyer[]
}

model Price {
  id        String   @id @default(cuid())
  productId String
  storeId   String
  price     Float
  salePrice Float?   // If on sale
  inStock   Boolean  @default(true)
  unit      String?  // "per kg", "each", etc.
  scrapedAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  store   Store   @relation(fields: [storeId], references: [id])

  @@unique([productId, storeId])
  @@index([productId])
  @@index([storeId])
}

// ─── FLYER MODELS ───

model Flyer {
  id         String   @id @default(cuid())
  storeId    String
  title      String
  validFrom  DateTime
  validTo    DateTime
  totalPages Int
  createdAt  DateTime @default(now())

  store Store       @relation(fields: [storeId], references: [id])
  pages FlyerPage[]

  @@index([storeId])
}

model FlyerPage {
  id         String @id @default(cuid())
  flyerId    String
  pageNumber Int
  imageUrl   String

  flyer Flyer       @relation(fields: [flyerId], references: [id], onDelete: Cascade)
  items FlyerItem[]

  @@unique([flyerId, pageNumber])
  @@index([flyerId])
}

model FlyerItem {
  id          String  @id @default(cuid())
  flyerPageId String
  productId   String? // linked product (null if not matched)
  name        String
  brand       String?
  size        String?
  price       Float
  originalPrice Float?
  saleStart   String?
  saleEnd     String?
  plu         String?
  upc         String?
  itemCode    String?
  // Bounding box coordinates (0-1 normalized)
  x           Float
  y           Float
  width       Float
  height      Float

  flyerPage FlyerPage @relation(fields: [flyerPageId], references: [id], onDelete: Cascade)
  product   Product?  @relation(fields: [productId], references: [id])

  @@index([flyerPageId])
  @@index([productId])
}

// ─── CART & ALERTS ───

model Cart {
  id             String   @id @default(cuid())
  userId         String
  name           String   @default("My Cart")
  optimizedTotal Float?   // Calculated best total
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id])
  items CartItem[]
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String
  productId String
  quantity  Int    @default(1)

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
}

model Alert {
  id          String   @id @default(cuid())
  userId      String
  productId   String
  targetPrice Float    // Notify when price drops below this
  triggered   Boolean  @default(false)
  triggeredAt DateTime?
  createdAt   DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
}
