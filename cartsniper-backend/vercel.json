{
  "version": 2,
  "buildCommand": "npm run build",
  "routes": [
    {
      "src": "\/(scan|prices|cart|alerts|flyer|health)(?:\/.*)?",
      "dest": "\/api\/index.js"
    },
    {
      "src": "\/flyer-images\/(.*)",
      "dest": "\/public\/flyer-images\/$1"
    },
    {
      "src": "\/",
      "dest": "\/public\/index.html"
    },
    {
      "src": "\/(.*)",
      "dest": "\/public\/$1"
    }
  ]
}
