{
  "version": 2,
  "buildCommand": "npm run build",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "\/(scan|prices|cart|alerts|flyer|health)(?:\/.*)?",
      "dest": "\/api\/index.js"
    },
    {
      "src": "\/",
      "dest": "\/index.html"
    },
    {
      "src": "\/(.*)",
      "dest": "\/index.html"
    }
  ]
}
